{
  "schema_version": "two_tower_data_contract_v1",
  "pipeline": {
    "stages": ["p0", "p1", "p2", "p3"],
    "seed": 20260410
  },
  "input": {
    "users_csv": "data/processed/users.csv",
    "songs_csv": "data/processed/songs.csv",
    "play_histories_csv": "data/processed/play_histories.csv",
    "play_counts_csv": "data/processed/play_counts.csv",
    "user_preference_csv": "data/processed/user_genre_preference_m2m.csv",
    "song_genre_csv": "data/processed/song_genre_m2m.csv"
  },
  "output": {
    "artifacts_root": "recsys/artifacts/two_tower",
    "datasets_dir": "recsys/artifacts/two_tower/datasets",
    "features_dir": "recsys/artifacts/two_tower/features",
    "reports_dir": "recsys/artifacts/two_tower/reports"
  },
  "p0": {
    "schema_json": "recsys/configs/two_tower/schema_v1.json"
  },
  "p1": {
    "sample_limit": null,
    "positive_target_threshold": 1,
    "negative_sampling_ratio": 3,
    "train_ratio": 0.8,
    "valid_ratio": 0.1,
    "test_ratio": 0.1,
    "min_user_positive_events": 3
  },
  "p2": {
    "age_bins": [18, 25, 35, 45, 55],
    "song_length_bins": [60000, 180000, 300000, 420000]
  },
  "p3": {
    "experiment_name": "two_tower_cloud_full",
    "training": {
      "embedding_dim": 128,
      "hidden_dims": [256, 128],
      "dropout": 0.1,
      "batch_size": 1024,
      "epochs": 10,
      "learning_rate": 0.0005,
      "weight_decay": 1e-5
    },
    "evaluation_k": [10, 50, 100]
  }
}
